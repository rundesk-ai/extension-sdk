{
    "name": "yourname/rundesk-{{ID}}",
    "type": "rundesk-extension",
    "require": {
        "php": "^8.4",
        "rundesk-ai/extension-sdk": "^1.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "orchestra/testbench": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "YourName\\{{NAMESPACE}}\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "YourName\\{{NAMESPACE}}\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
